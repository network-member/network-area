{
  "name": "network-area-api",
  "version": "1.0.0",
  "type": "module",
  "author": "Vladislav Kazantsev",
  "license": "MIT",
  "scripts": {
    "_ts-node": "node --loader ./esm-loader.mjs --env-file=.env --enable-source-maps",
    "start:dev": "npm run _ts-node -- --no-deprecation --disable-warning=ExperimentalWarning src/server.ts",
    "build": "rimraf ./build && tsc && tsc-alias",
    "start": "node --enable-source-maps --env-file=.env build/server.js",
    "check-types": "tsc --noEmit",
    "test": "NODE_OPTIONS='--experimental-vm-modules --env-file=.env' jest --config jest.config.mjs",
    "orm:cli": "npm run _ts-node -- ../node_modules/@mikro-orm/cli/cli.js",
    "db:seeds": "npm run orm:cli -- seeder:run -c DatabaseSeeder",
    "db:wipe-data": "npm run orm:cli -- schema:fresh --seed --run"
  },
  "dependencies": {
    "@mikro-orm/core": "^6.6.4",
    "@mikro-orm/migrations": "^6.6.4",
    "@mikro-orm/postgresql": "^6.6.4",
    "@mikro-orm/seeder": "^6.6.4",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "es-toolkit": "^1.43.0",
    "express": "^5.2.1",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "redis": "^5.10.0",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@mikro-orm/cli": "^6.6.4",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "jest": "^30.3.0",
    "rimraf": "^6.1.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0"
  }
}
